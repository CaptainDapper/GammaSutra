<UserControl x:Class="GammaControl.Controls.GammaCurveControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Canvas x:Name="CurveCanvas"
                ClipToBounds="True"
                Background="#111111"
                MouseDown="CurveCanvas_MouseDown"
                MouseMove="CurveCanvas_MouseMove"
                MouseUp="CurveCanvas_MouseUp"
                MouseWheel="CurveCanvas_MouseWheel"/>
        <Button x:Name="ResetZoomButton"
                Content="Reset Zoom"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,4,0" Padding="4,2"
                FontSize="10" Opacity="0.7"
                Visibility="Collapsed"
                Click="ResetZoomButton_Click"/>
    </Grid>
</UserControl>
