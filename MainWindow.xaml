<Window x:Class="GammaControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GammaControl.Controls"
        Title="Gamma Sutra: Definitely Not Cheating" Height="500" Width="520"
        ResizeMode="NoResize"
        Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Monitor selector + Draw Mode toggle -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Monitor:" VerticalAlignment="Center" Padding="0,0,4,0"/>
            <ComboBox x:Name="MonitorComboBox" Grid.Column="1"
                      VerticalAlignment="Center"
                      SelectionChanged="MonitorComboBox_SelectionChanged"/>
            <Button x:Name="ApplyAllButton" Grid.Column="2" Content="All"
                    Width="36" Margin="6,0,0,0"
                    Click="ApplyAllButton_Click"/>
            <ToggleButton x:Name="DrawModeButton" Grid.Column="3" Content="Draw Mode"
                          Margin="6,0,0,0" Padding="6,2"
                          Checked="DrawModeButton_Checked"
                          Unchecked="DrawModeButton_Unchecked"/>
        </Grid>

        <!-- Row 1: Curve graph -->
        <Border Grid.Row="1" BorderBrush="#555555" BorderThickness="1" Margin="0,0,0,6">
            <controls:GammaCurveControl x:Name="CurveControl"
                                        DrawnRampChanged="CurveControl_DrawnRampChanged"/>
        </Border>

        <!-- Row 2: Parametric sliders — 2-column layout
             Left:  Gamma / Brightness / Contrast
             Right: S-Curve / Highlights / Shadows  -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <!-- Left column -->
            <Label Grid.Row="0" Grid.Column="0" Content="Gamma"      VerticalAlignment="Center" Padding="0"/>
            <Slider x:Name="GammaSlider"      Grid.Row="0" Grid.Column="1"
                    Minimum="0.1" Maximum="5.0" Value="1.0"
                    SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="GammaLabel"    Grid.Row="0" Grid.Column="2"
                       Text="1.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Brightness" VerticalAlignment="Center" Padding="0"/>
            <Slider x:Name="BrightnessSlider" Grid.Row="1" Grid.Column="1"
                    Minimum="-0.5" Maximum="0.5" Value="0.0"
                    SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="BrightnessLabel" Grid.Row="1" Grid.Column="2"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="2" Grid.Column="0" Content="Contrast"   VerticalAlignment="Center" Padding="0"/>
            <Slider x:Name="ContrastSlider"   Grid.Row="2" Grid.Column="1"
                    Minimum="0.0" Maximum="2.0" Value="1.0"
                    SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="ContrastLabel" Grid.Row="2" Grid.Column="2"
                       Text="1.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <!-- Right column -->
            <Label Grid.Row="0" Grid.Column="4" Content="S-Curve"    VerticalAlignment="Center" Padding="0"
                   ToolTip="Sigmoid contrast: positive = punch shadows/highlights, negative = flatten"/>
            <Slider x:Name="SCurveSlider"     Grid.Row="0" Grid.Column="5"
                    Minimum="-1.0" Maximum="1.0" Value="0.0"
                    SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="SCurveLabel"   Grid.Row="0" Grid.Column="6"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="1" Grid.Column="4" Content="Highlights" VerticalAlignment="Center" Padding="0"
                   ToolTip="Quadratic highlight lift/pull — only affects bright values (v²)"/>
            <Slider x:Name="HighlightsSlider" Grid.Row="1" Grid.Column="5"
                    Minimum="-0.5" Maximum="0.5" Value="0.0"
                    SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="HighlightsLabel" Grid.Row="1" Grid.Column="6"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="2" Grid.Column="4" Content="Shadows"    VerticalAlignment="Center" Padding="0"
                   ToolTip="Quadratic shadow lift/pull — only affects dark values ((1-v)²)"/>
            <Slider x:Name="ShadowsSlider"    Grid.Row="2" Grid.Column="5"
                    Minimum="-0.5" Maximum="0.5" Value="0.0"
                    SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="ShadowsLabel"  Grid.Row="2" Grid.Column="6"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>

        <!-- Row 3: Profile — name label + Save (appears when dirty) + Revert + Profiles -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Profile:" VerticalAlignment="Center" Padding="0,0,4,0"/>
            <TextBlock x:Name="CurrentProfileLabel" Grid.Column="1"
                       Text="(none)" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button x:Name="SaveProfileButton" Grid.Column="2" Content="Save"
                    Margin="6,0,0,0" Padding="8,2" Visibility="Collapsed"
                    Click="SaveProfileButton_Click"/>
            <Button Grid.Column="3" Content="Revert"
                    Margin="4,0,0,0" Padding="8,2"
                    Click="RevertProfileButton_Click"/>
            <Button Grid.Column="4" Content="Profiles..."
                    Margin="4,0,0,0" Padding="8,2"
                    Click="ManageProfilesButton_Click"/>
        </Grid>

        <!-- Row 4: Reset Gamma -->
        <Grid Grid.Row="4">
            <Button HorizontalAlignment="Right" Content="Reset Gamma"
                    Padding="8,2" Click="ResetButton_Click"/>
        </Grid>
    </Grid>
</Window>
