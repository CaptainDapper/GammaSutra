<Window x:Class="GammaControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GammaControl.Controls"
        Title="Gamma Sutra: Definitely Not Cheating" Width="520"
        SizeToContent="Height" ResizeMode="NoResize"
        Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Monitor selector + channel buttons + Draw/Bezier -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Monitor:" VerticalAlignment="Center" Padding="0,0,4,0"/>
            <ComboBox x:Name="MonitorComboBox" Grid.Column="1"
                      VerticalAlignment="Center"
                      SelectionChanged="MonitorComboBox_SelectionChanged"/>
            <Separator Grid.Column="2" Margin="6,2,0,2" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
            <ToggleButton x:Name="ChannelAllButton" Grid.Column="3" Content="All"
                          Margin="4,0,0,0" Padding="4,2" IsChecked="True"
                          Click="ChannelButton_Click"/>
            <ToggleButton x:Name="ChannelRButton" Grid.Column="4" Content="R"
                          Margin="2,0,0,0" Padding="4,2" Foreground="#FF4444"
                          Click="ChannelButton_Click"/>
            <ToggleButton x:Name="ChannelGButton" Grid.Column="5" Content="G"
                          Margin="2,0,0,0" Padding="4,2" Foreground="#44CC44"
                          Click="ChannelButton_Click"/>
            <ToggleButton x:Name="ChannelBButton" Grid.Column="6" Content="B"
                          Margin="2,0,0,0" Padding="4,2" Foreground="#4488FF"
                          Click="ChannelButton_Click"/>
            <Separator Grid.Column="7" Margin="4,2,0,2" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
            <ToggleButton x:Name="SlidersModeButton" Grid.Column="8" Content="Sliders"
                          Margin="4,0,0,0" Padding="6,2" IsChecked="True"
                          Click="ModeButton_Click"/>
            <ToggleButton x:Name="NodeModeButton" Grid.Column="9" Content="Node"
                          Margin="2,0,0,0" Padding="6,2"
                          Click="ModeButton_Click"/>
            <ToggleButton x:Name="BezierModeButton" Grid.Column="10" Content="Bezier"
                          Margin="2,0,0,0" Padding="6,2"
                          Click="ModeButton_Click"/>
        </Grid>

        <!-- Row 1: Curve graph -->
        <Border Grid.Row="1" BorderBrush="#555555" BorderThickness="1" Margin="0,0,0,6">
            <controls:GammaCurveControl x:Name="CurveControl"
                                        DrawnRampChanged="CurveControl_DrawnRampChanged"
                                        BezierPointsChanged="CurveControl_BezierPointsChanged"
                                        NodePointsChanged="CurveControl_NodePointsChanged"/>
        </Border>

        <!-- Row 2: Parametric sliders — 2-column layout -->
        <Grid x:Name="SlidersGrid" Grid.Row="2" Margin="0,0,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <!-- Left column -->
            <Label Grid.Row="0" Grid.Column="0" Content="Gamma"      VerticalAlignment="Center" Padding="0"/>
            <Slider x:Name="GammaSlider"      Grid.Row="0" Grid.Column="1"
                    Minimum="0.1" Maximum="5.0" Value="1.0"
                    SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="GammaLabel"    Grid.Row="0" Grid.Column="2"
                       Text="1.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Brightness" VerticalAlignment="Center" Padding="0"/>
            <Slider x:Name="BrightnessSlider" Grid.Row="1" Grid.Column="1"
                    Minimum="-0.5" Maximum="0.5" Value="0.0"
                    SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="BrightnessLabel" Grid.Row="1" Grid.Column="2"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="2" Grid.Column="0" Content="Contrast"   VerticalAlignment="Center" Padding="0"/>
            <Slider x:Name="ContrastSlider"   Grid.Row="2" Grid.Column="1"
                    Minimum="0.0" Maximum="2.0" Value="1.0"
                    SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="ContrastLabel" Grid.Row="2" Grid.Column="2"
                       Text="1.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <!-- Right column -->
            <Label Grid.Row="0" Grid.Column="4" Content="S-Curve"    VerticalAlignment="Center" Padding="0"
                   ToolTip="Sigmoid contrast: positive = punch shadows/highlights, negative = flatten"/>
            <Slider x:Name="SCurveSlider"     Grid.Row="0" Grid.Column="5"
                    Minimum="-1.0" Maximum="1.0" Value="0.0"
                    SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="SCurveLabel"   Grid.Row="0" Grid.Column="6"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="1" Grid.Column="4" Content="Highlights" VerticalAlignment="Center" Padding="0"
                   ToolTip="Quadratic highlight lift/pull — only affects bright values (v²)"/>
            <Slider x:Name="HighlightsSlider" Grid.Row="1" Grid.Column="5"
                    Minimum="-0.5" Maximum="0.5" Value="0.0"
                    SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="HighlightsLabel" Grid.Row="1" Grid.Column="6"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

            <Label Grid.Row="2" Grid.Column="4" Content="Shadows"    VerticalAlignment="Center" Padding="0"
                   ToolTip="Quadratic shadow lift/pull — only affects dark values ((1-v)²)"/>
            <Slider x:Name="ShadowsSlider"    Grid.Row="2" Grid.Column="5"
                    Minimum="-0.5" Maximum="0.5" Value="0.0"
                    SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="ShadowsLabel"  Grid.Row="2" Grid.Column="6"
                       Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>

        <!-- Row 3: Posterize (collapsed by default) -->
        <Expander x:Name="PosterizeExpander" Grid.Row="3" Header="Posterize" Margin="0,0,0,6"
                  IsExpanded="False">
            <Grid x:Name="PosterizeGrid" Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Steps" VerticalAlignment="Center" Padding="0"
                       ToolTip="Posterize: 0=off, 2-32 = number of output levels"/>
                <Slider x:Name="PosterizeStepsSlider" Grid.Row="0" Grid.Column="1"
                        Minimum="0" Maximum="32" Value="0" IsSnapToTickEnabled="True" TickFrequency="1"
                        SmallChange="1" LargeChange="4" VerticalAlignment="Center"
                        ValueChanged="PosterizeSlider_ValueChanged"/>
                <TextBlock x:Name="PosterizeStepsLabel" Grid.Row="0" Grid.Column="2"
                           Text="0" VerticalAlignment="Center" TextAlignment="Right"/>

                <Label Grid.Row="0" Grid.Column="4" Content="Feather" VerticalAlignment="Center" Padding="0"
                       ToolTip="Width of the blend zone at each range edge"/>
                <Slider x:Name="PosterizeFeatherSlider" Grid.Row="0" Grid.Column="5"
                        Minimum="0.0" Maximum="0.3" Value="0.1"
                        SmallChange="0.01" LargeChange="0.05" VerticalAlignment="Center"
                        ValueChanged="PosterizeSlider_ValueChanged"/>
                <TextBlock x:Name="PosterizeFeatherLabel" Grid.Row="0" Grid.Column="6"
                           Text="0.10" VerticalAlignment="Center" TextAlignment="Right"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Range Min" VerticalAlignment="Center" Padding="0"
                       ToolTip="Normalized input position where posterize begins"/>
                <Slider x:Name="PosterizeRangeMinSlider" Grid.Row="1" Grid.Column="1"
                        Minimum="0.0" Maximum="1.0" Value="0.0"
                        SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                        ValueChanged="PosterizeSlider_ValueChanged"/>
                <TextBlock x:Name="PosterizeRangeMinLabel" Grid.Row="1" Grid.Column="2"
                           Text="0.00" VerticalAlignment="Center" TextAlignment="Right"/>

                <Label Grid.Row="1" Grid.Column="4" Content="Range Max" VerticalAlignment="Center" Padding="0"
                       ToolTip="Normalized input position where posterize ends"/>
                <Slider x:Name="PosterizeRangeMaxSlider" Grid.Row="1" Grid.Column="5"
                        Minimum="0.0" Maximum="1.0" Value="1.0"
                        SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"
                        ValueChanged="PosterizeSlider_ValueChanged"/>
                <TextBlock x:Name="PosterizeRangeMaxLabel" Grid.Row="1" Grid.Column="6"
                           Text="1.00" VerticalAlignment="Center" TextAlignment="Right"/>
            </Grid>
        </Expander>

        <!-- Row 4: Profile -->
        <Grid Grid.Row="4" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Profile:" VerticalAlignment="Center" Padding="0,0,4,0"/>
            <TextBlock x:Name="CurrentProfileLabel" Grid.Column="1"
                       Text="(none)" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button x:Name="SaveProfileButton" Grid.Column="2" Content="Save"
                    Margin="6,0,0,0" Padding="8,2" Visibility="Collapsed"
                    Click="SaveProfileButton_Click"/>
            <Button Grid.Column="3" Content="Revert"
                    Margin="4,0,0,0" Padding="8,2"
                    Click="RevertProfileButton_Click"/>
            <Button Grid.Column="4" Content="Profiles..."
                    Margin="4,0,0,0" Padding="8,2"
                    Click="ManageProfilesButton_Click"/>
        </Grid>

        <!-- Row 5: Reset Gamma -->
        <Grid Grid.Row="5">
            <Button HorizontalAlignment="Right" Content="Reset Gamma"
                    Padding="8,2" Click="ResetButton_Click"/>
        </Grid>
    </Grid>
</Window>
